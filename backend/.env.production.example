APP_DEPLOY_ENV=production
APP_RELEASE_CHANNEL=stable
APP_BUILD_VERSION=0.1.0
APP_BUILD_SHA=prod-build-sha
SUPABASE_URL=https://prod-project.supabase.co
SUPABASE_KEY=prod-service-role-key
SUPABASE_SERVICE_ROLE_KEY=prod-service-role-key
SUPABASE_ANON_KEY=prod-public-anon-key
SUPABASE_JWT_SECRET=prod-jwt-secret
GEMINI_API_KEY=prod-gemini-api-key
GEMINI_CLIENT_PROVIDER=genai
GEMINI_VERTEX_PROJECT=your-gcp-project-id
GEMINI_VERTEX_LOCATION=global
AI_MODEL_NAME=gemini-3-pro-preview
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
BACKEND_PUBLIC_URL=https://api.promdata.com
FRONTEND_APP_URL=https://app.promdata.com
GOOGLE_DRIVE_CLIENT_ID=prod-google-client-id
GOOGLE_DRIVE_CLIENT_SECRET=prod-google-client-secret
GOOGLE_DRIVE_SCOPES=openid email profile https://www.googleapis.com/auth/drive.readonly
GOOGLE_DRIVE_WATCH_MODE=webhook
GOOGLE_DRIVE_WEBHOOK_CALLBACK_URL=https://api.promdata.com/api/v1/connectors/google-drive/webhook
GOOGLE_DRIVE_WEBHOOK_EXPIRATION_SECONDS=604800
GOOGLE_DRIVE_WEBHOOK_RENEWAL_SKEW_SECONDS=3600
MICROSOFT_ONEDRIVE_CLIENT_ID=prod-microsoft-client-id
MICROSOFT_ONEDRIVE_CLIENT_SECRET=prod-microsoft-client-secret
MICROSOFT_ONEDRIVE_SCOPES=offline_access openid profile email Files.Read User.Read
MICROSOFT_ONEDRIVE_TENANT_ID=common
MICROSOFT_ONEDRIVE_WATCH_MODE=polling
CONNECTOR_WATCHDOG_ENABLED=true
CONNECTOR_AUTO_SYNC_ENABLED=true
CONNECTOR_POLL_INTERVAL_SECONDS=120
RATE_LIMIT_ENABLED=true
RATE_LIMIT_STORAGE_URL=redis://redis:6379/0

# [FIX 2026-06-08] Soft limit para payload JSON en analysis_tasks.results_json
# Subido de 1.5MB (default) a 4MB para preservar snapshot_arrow y arrow_data
# necesarios para el cross-filter del frontend ("Filtrar aquí" sobre gráficos).
# El cap interno del canary executor sigue siendo 4MB por field (granular_arrow).
UNIVERSAL_TABULAR_RESULT_SOFT_LIMIT_BYTES=4000000
