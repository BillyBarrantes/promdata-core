APP_DEPLOY_ENV=staging
APP_RELEASE_CHANNEL=canary
APP_BUILD_VERSION=0.1.0-staging
APP_BUILD_SHA=staging-build-sha
SUPABASE_URL=https://staging-project.supabase.co
SUPABASE_KEY=staging-service-role-key
SUPABASE_SERVICE_ROLE_KEY=staging-service-role-key
SUPABASE_ANON_KEY=staging-public-anon-key
SUPABASE_JWT_SECRET=staging-jwt-secret
GEMINI_API_KEY=staging-gemini-api-key
GEMINI_CLIENT_PROVIDER=genai
GEMINI_VERTEX_PROJECT=your-gcp-project-id
GEMINI_VERTEX_LOCATION=global
AI_MODEL_NAME=gemini-3-pro-preview
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
BACKEND_PUBLIC_URL=https://staging-api.promdata.local
FRONTEND_APP_URL=https://staging.promdata.local
GOOGLE_DRIVE_CLIENT_ID=staging-google-client-id
GOOGLE_DRIVE_CLIENT_SECRET=staging-google-client-secret
GOOGLE_DRIVE_SCOPES=openid email profile https://www.googleapis.com/auth/drive.readonly
GOOGLE_DRIVE_WATCH_MODE=webhook
GOOGLE_DRIVE_WEBHOOK_CALLBACK_URL=https://staging-api.promdata.local/api/v1/connectors/google-drive/webhook
GOOGLE_DRIVE_WEBHOOK_EXPIRATION_SECONDS=604800
GOOGLE_DRIVE_WEBHOOK_RENEWAL_SKEW_SECONDS=3600
MICROSOFT_ONEDRIVE_CLIENT_ID=staging-microsoft-client-id
MICROSOFT_ONEDRIVE_CLIENT_SECRET=staging-microsoft-client-secret
MICROSOFT_ONEDRIVE_SCOPES=offline_access openid profile email Files.Read User.Read
MICROSOFT_ONEDRIVE_TENANT_ID=common
MICROSOFT_ONEDRIVE_WATCH_MODE=polling
CONNECTOR_WATCHDOG_ENABLED=true
CONNECTOR_AUTO_SYNC_ENABLED=true
CONNECTOR_POLL_INTERVAL_SECONDS=180
RATE_LIMIT_ENABLED=true
RATE_LIMIT_STORAGE_URL=redis://redis:6379/0
