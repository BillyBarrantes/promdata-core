APP_DEPLOY_ENV=development
APP_RELEASE_CHANNEL=local
APP_BUILD_VERSION=0.1.0-local
APP_BUILD_SHA=local
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-public-anon-key
SUPABASE_JWT_SECRET=your-jwt-secret
GEMINI_API_KEY=your-gemini-api-key
GEMINI_CLIENT_PROVIDER=genai
GEMINI_VERTEX_PROJECT=your-gcp-project-id
GEMINI_VERTEX_LOCATION=global
AI_MODEL_NAME=gemini-3-pro-preview
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
BACKEND_PUBLIC_URL=http://localhost:8000
FRONTEND_APP_URL=http://localhost:3000
GOOGLE_DRIVE_CLIENT_ID=your-google-client-id
GOOGLE_DRIVE_CLIENT_SECRET=your-google-client-secret
GOOGLE_DRIVE_SCOPES=openid email profile https://www.googleapis.com/auth/drive.readonly
GOOGLE_DRIVE_WATCH_MODE=webhook
GOOGLE_DRIVE_WEBHOOK_CALLBACK_URL=http://localhost:8000/api/v1/connectors/google-drive/webhook
GOOGLE_DRIVE_WEBHOOK_EXPIRATION_SECONDS=604800
GOOGLE_DRIVE_WEBHOOK_RENEWAL_SKEW_SECONDS=3600
MICROSOFT_ONEDRIVE_CLIENT_ID=your-microsoft-client-id
MICROSOFT_ONEDRIVE_CLIENT_SECRET=your-microsoft-client-secret
MICROSOFT_ONEDRIVE_SCOPES=offline_access openid profile email Files.Read User.Read
MICROSOFT_ONEDRIVE_TENANT_ID=common
MICROSOFT_ONEDRIVE_WATCH_MODE=polling
CONNECTOR_WATCHDOG_ENABLED=false
CONNECTOR_AUTO_SYNC_ENABLED=true
CONNECTOR_POLL_INTERVAL_SECONDS=300
RATE_LIMIT_ENABLED=true
RATE_LIMIT_STORAGE_URL=redis://redis:6379/0
CANONICAL_NATIVE_TABULAR_EXTRACTION_ENABLED=false
CANONICAL_IBIS_PREVIEW_RUNTIME_ENABLED=false
CANONICAL_ANALYTICAL_CONTRACT_ADAPTER_ENABLED=false
CANONICAL_SHADOW_METRIC_VALIDITY_GATE_ENABLED=false
CANONICAL_SHADOW_QUERY_RUNTIME_ENABLED=false
CANONICAL_SHADOW_TRAFFIC_MIRROR_ENABLED=false
CANONICAL_SHADOW_TRAFFIC_MIRROR_TABULAR_ONLY=true
CANONICAL_SHADOW_TRAFFIC_MIRROR_MAX_PLANS=3
CANONICAL_TABULAR_CANARY_ROUTER_ENABLED=false
CANONICAL_TABULAR_CANARY_FUNCTIONAL_SWITCH_ENABLED=false
CANONICAL_TABULAR_CANARY_FAIL_OPEN_ENABLED=true
CANONICAL_TABULAR_CANARY_TRAFFIC_PERCENT=0
CANONICAL_TABULAR_CANARY_ALLOWLIST_TEAM_IDS=
CANONICAL_TABULAR_CANARY_ALLOWLIST_USER_IDS=
CANONICAL_TABULAR_CANARY_ALLOWLIST_FILE_IDS=
CANONICAL_TABULAR_CANARY_REQUIRE_SHADOW_EVIDENCE=true
CANONICAL_TABULAR_CANARY_MIN_OBSERVED_TASKS=12
CANONICAL_TABULAR_CANARY_MIN_ALIGNMENT_RATE=0.98
CANONICAL_TABULAR_CANARY_MAX_DIVERGENCE_SCORE=0.02
